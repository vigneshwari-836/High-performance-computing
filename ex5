#include <stdio.h>
#include <stdlib.h>
#include <pthread.h>
int *arr;
int *partial_sum;
int n, num;
typedef struct {
   int thread_id;
   int start;
   int end;
} threadData;
void* compute(void* arg) {
   threadData* data = (threadData*)arg;
   int local = 0,i;
   for(int i = data->start; i < data->end; i++) {
      local += arr[i];
   }
   partial_sum[data->thread_id] = local;
   return NULL;
}
int main(int argc, char* argv[]) {
   if (argc < 2) {
      printf("Usage: %s <number_of_threads>\n", argv[0]);
      return 1;
   }
   int i;
   num = strtol(argv[1], NULL, 10);
   printf("Enter the array size: ");
   scanf("%d", &n);
   pthread_t *thread_handles = (pthread_t*)malloc(num * sizeof(pthread_t));
   threadData *data = (threadData*)malloc(num * sizeof(threadData));
   arr = (int*)malloc(n * sizeof(int));
   partial_sum = (int*)malloc(num * sizeof(int));

   for(int i = 0; i < n; i++) {
      arr[i] = rand() % 100;
   }
   printf("\nArray elements:");
   for(i=0;i<n;i++){
      printf("%d ",arr[i]);
   }
   int ch = n / num;
   for(int i = 0; i < num; i++) {
      data[i].thread_id = i;
      data[i].start = i * ch;
      if(i == num - 1) {
         data[i].end = n;
      } else {
         data[i].end = (i + 1) * ch;
      }
      pthread_create(&thread_handles[i], NULL, compute, &data[i]);
   }
   for(int i = 0; i < num; i++) {
      pthread_join(thread_handles[i], NULL);
   }
   int total = 0;
   for(int i = 0; i < num; i++) {
      total += partial_sum[i];
   }
   printf("Total sum: %d\n", total);
   free(arr);
   free(partial_sum);
   free(thread_handles);
   free(data);

   return 0;
}


