    for(int i = 0; i < n; i++) {
        for(int j = 0; j < n; j++) {
            mat[i][j] = rand() % 10;
        }
    }
    printf("Matrix \n");
    for(int i=0;i<n;i++)
    {
       for(int j=0;j<n;j++)
       {
          printf("%d ",mat[i][j]);
       }
       printf("\n");
    }
}

void* add_matrix(void* arg) {
    D =(int**) malloc(n * sizeof(int*));
    for(int i = 0; i < n; i++) {
        D[i] =(int*) malloc(n * sizeof(int));
        for(int j = 0; j < n; j++) {
            D[i][j] = A[i][j] + B[i][j];
        }
    }
    printf("\n--- Addition Result ---\n");
    for(int i = 0; i < n; i++) {
        for(int j = 0; j < n; j++) printf("%d ", D[i][j]);
        printf("\n");
    }
    return NULL;
}

void* mul_matrix(void* arg) {
    C = (int**)malloc(n * sizeof(int*));
    for(int i = 0; i < n; i++) {
        C[i] = (int*) malloc(n * sizeof(int));
        for(int j = 0; j < n; j++) {
