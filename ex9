#include <stdio.h>
#include <omp.h>
#define ROWS 3
#define COLS 3
int main() {
    int matrix[ROWS][COLS];
    int k, total_sum = 0;
    int i,j;
    // Initialize matrix with some values
    for ( i = 0; i < ROWS; i++)
    {
        for ( j = 0; j < COLS; j++)
        {
            matrix[i][j] = i + j;
            printf("%d ",matrix[i][j]);

        }
        printf("\n");
    }

    printf("Enter divisor k: ");
    scanf("%d", &k);
    // Parallelize the outer loop
    #pragma omp parallel for reduction(+:total_sum) collapse(2)
    for ( i = 0; i < ROWS; i++) {
        for ( j = 0; j < COLS; j++) {
            if (matrix[i][j] % k == 0) {
                total_sum += matrix[i][j];
            }
        }
    }
    printf("Total sum of elements divisible by %d: %d\n", k, total_sum);
    return 0;
}

