#include <stdio.h>
#include <omp.h>
/* The function to integrate: f(x) = x^2 */ double f(double x) {
    return x * x;
}
int main() {
    double a, b;
    int n;
    /* Get input from the user */
    printf("Enter the left endpoint (a): ");
    scanf("%lf", &a);
    printf("Enter the right endpoint (b): ");
    scanf("%lf", &b);
    printf("Enter the number of trapezoids (n): ");
    scanf("%d", &n);
    double h = (b - a) / n;

    // --- METHOD 1: REDUCTION ---
    double total_sum_red = (f(a) + f(b)) / 2.0;
    int i;
    #pragma omp parallel for reduction(+:total_sum_red)
    for ( i = 1; i < n; i++) {
        total_sum_red += f(a + i * h);
    }
    printf("\nResult (Reduction): %f\n", total_sum_red * h);
    // --- METHOD 2: CRITICAL ---
    double total_sum_crit = (f(a) + f(b)) / 2.0;
    #pragma omp parallel
    {
        double local_sum = 0.0;
        #pragma omp for
        for ( i = 1; i < n; i++) {
            local_sum += f(a + i * h);
        }

        /* Ensures only one thread updates the global variable at a time */
        #pragma omp critical
        {
            total_sum_crit += local_sum;
        }
    }
    printf("Result (Critical): %f\n", total_sum_crit * h);
    return 0;
}
