#include <stdio.h>
#include <omp.h>
//#define SIZE 10
int main() {
   int SIZE;
   printf("Enter size:");
   scanf("%d",&SIZE);
    int mat[SIZE][SIZE];
    int row_min[SIZE], col_max[SIZE];
    int i=0,j=0;
    int saddle_count = 0;
    // 1. Initialize matrix
    for ( i = 0; i < SIZE; i++)
        for ( j = 0; j < SIZE; j++)
            scanf("%d",&mat[i][j] );
    // 2. Find Minimum of each Row
    #pragma omp parallel for
    for ( i = 0; i < SIZE; i++) {
        int min = mat[i][0];
        for ( j = 1; j < SIZE; j++) {
            if (mat[i][j] < min) min = mat[i][j];
        }
        row_min[i] = min;
    }
    // 3. Find Maximum of each Column
    #pragma omp parallel for
    for ( j = 0; j < SIZE; j++) {
        int max = mat[0][j];
        for ( i = 1; i < SIZE; i++) {
            if (mat[i][j] > max) max = mat[i][j];
        }
        col_max[j] = max;
    }
    // 4. Count Saddle Points using Reduction
    #pragma omp parallel for reduction(+:saddle_count) collapse(2)
    for ( i = 0; i < SIZE; i++) {
        for ( j = 0; j < SIZE; j++) {
            if (mat[i][j] == row_min[i] && mat[i][j] == col_max[j]) {
                saddle_count++;
            }
        }
    }
    printf("Number of Saddle Points: %d\n", saddle_count);
    return 0;
}
