    scanf("%d", &SIZE);
    printf("Enter scalar value to add: ");
    scanf("%d", &constant);
    A = (int*) malloc(SIZE * sizeof(int));
    for(i = 0; i < SIZE; i++)
    {
        A[i] = i;
    }
    #pragma omp parallel for num_threads(4)
    for(i = 0; i < SIZE; i++)
    {
        A[i] = A[i] + constant;
    }
    printf("First 50 elements after adding the scalar value:\n");
    for(i = 0; i < SIZE && i < 50; i++)
    {
        printf("%d ", A[i]);
    }
    printf("\n\n");
    free(A);
    return 0;
}

