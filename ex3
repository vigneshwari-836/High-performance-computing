#include<stdio.h>
#include<stdlib.h>
#include<mpi.h>

int main(int argc, char** argv)
{
    int my_rank, commsz;
    int n, num, i;
    int *arr = NULL, *sub;
    int *sendcounts = NULL, *displs = NULL;
    int local_count = 0, total_count = 0;

    MPI_Init(&argc, &argv);
    MPI_Comm_rank(MPI_COMM_WORLD, &my_rank);
    MPI_Comm_size(MPI_COMM_WORLD, &commsz);

    if (my_rank == 0) {
        printf("Enter no. of elements: ");
        fflush(stdout);
        scanf("%d", &n);

        arr = (int*)malloc(n * sizeof(int));
        printf("Array elements: ");
        for (i = 0; i < n; i++) {
            arr[i] = rand() % 10;
            printf("%d ", arr[i]);
        }
        printf("\n");

        printf("Enter no. to search: ");
        fflush(stdout);
        scanf("%d", &num);
    }


    MPI_Bcast(&n, 1, MPI_INT, 0, MPI_COMM_WORLD);
    MPI_Bcast(&num, 1, MPI_INT, 0, MPI_COMM_WORLD);


    sendcounts = (int*)malloc(commsz * sizeof(int));
    displs = (int*)malloc(commsz * sizeof(int));

    int sum = 0;
    int base_size = n / commsz;
    int remainder = n % commsz;

    for (i = 0; i < commsz; i++) {
        sendcounts[i] = base_size + (i < remainder ? 1 : 0);
        displs[i] = sum;
        sum += sendcounts[i];
    }


    sub = (int*)malloc(sendcounts[my_rank] * sizeof(int));


    MPI_Scatterv(arr, sendcounts, displs, MPI_INT, sub, sendcounts[my_rank], MPI_INT, 0, MPI_COMM_WORLD);

    local_count = 0;
    for (i = 0; i < sendcounts[my_rank]; i++) {
        if (sub[i] == num)
            local_count++;
    }

    MPI_Reduce(&local_count, &total_count, 1, MPI_INT, MPI_SUM, 0, MPI_COMM_WORLD);

    if (my_rank == 0) {
        printf("Frequency of %d is %d \n", num, total_count);
        free(arr);
    }

    free(sub);
    free(sendcounts);
    free(displs);
    MPI_Finalize();
    return 0;
}

